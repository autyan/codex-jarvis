{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Jarvis",
  "version": "0.1.0",
  "identifier": "dev.autyan.codex-jarvis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Jarvis",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "rpm", "deb"],
    "icon": [
      "../assets/icons/32x32.png",
      "../assets/icons/128x128.png",
      "../assets/icons/128x128@2x.png",
      "../assets/icon.svg"
    ]
  }
}

