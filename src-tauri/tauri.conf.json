{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Jarvis",
  "version": "0.1.0",
  "identifier": "dev.autyan.codex-jarvis",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Jarvis",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm", "deb"],
    "category": "Utility",
    "shortDescription": "Linux desktop control panel for Codex CLI",
    "longDescription": "Codex Jarvis is a Linux desktop control panel for Codex CLI focused on safe local workstation maintenance tasks.",
    "icon": [
      "../assets/icons/32x32.png",
      "../assets/icons/128x128.png",
      "../assets/icons/128x128@2x.png",
      "../assets/icon.svg"
    ]
  }
}
